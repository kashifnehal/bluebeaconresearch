# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_PRICE_ANALYST=your_analyst_price_id
STRIPE_PRICE_PRO=your_pro_price_id
STRIPE_PRICE_API=your_api_price_id

# Anthropic Claude (AI Processing)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Market Data (Alpha Vantage / NewsAPI / ACLED)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_news_api_key
GNEWS_API_KEY=your_gnews_api_key
ACLED_API_KEY=your_acled_api_key
ACLED_API_EMAIL=your_acled_email

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Communication (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=alerts@yourdomain.com

# Geospatial (Mapbox)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Database/Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=your_redis_url
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Observability (Sentry / PostHog)
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_next_public_sentry_dsn
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Deployment URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001